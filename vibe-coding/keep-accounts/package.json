{
  "name": "keep-accounts",
  "private": true,
  "version": "1.0.0",
  "description": "生活财务小管家 - 个人桌面记账软件",
  "author": "phvioplie",
  "main": "process/main.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE concurrently \"npx vite\" \"npx wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE npx electron .\"",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3 -v 33.4.11 --module-dir .",
    "package:mac": "npx vite build && npx electron-builder --mac",
    "package:win": "npx vite build && npx electron-builder --win",
    "lint": "npx oxlint"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.keepaccounts.app",
    "productName": "生活财务小管家",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "process/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "unicode": true
    }
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron@33.4.11": true,
    "electron-winstaller@5.4.0": true,
    "fsevents@2.3.3": true
  }
}
